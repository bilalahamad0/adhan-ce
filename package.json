{
  "name": "adhan-caster-pro",
  "version": "2.0.1",
  "description": "Chrome extension for Muslim prayer times — a live Adhan countdown that auto-pauses video & audio in every browser tab at prayer time. Privacy-first, no ads, no tracking.",
  "keywords": [
    "adhan",
    "azan",
    "prayer times",
    "muslim prayer times",
    "salah",
    "namaz",
    "islamic",
    "prayer reminder",
    "prayer notification",
    "chrome-extension",
    "manifest-v3",
    "fajr",
    "dhuhr",
    "asr",
    "maghrib",
    "isha"
  ],
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "test:watch": "node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:cov": "node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage",
    "pack": "bash docs/pack.sh",
    "pack:crx": "node scripts/pack-crx.mjs",
    "pack:xpi": "node scripts/pack-xpi.mjs",
    "lint:firefox": "node scripts/pack-xpi.mjs && addons-linter dist/firefox",
    "submit:cws": "node scripts/submit-cws.mjs",
    "icons": "node icons/generate-icons.cjs",
    "demo": "bash docs/make-demo.sh",
    "shots": "bash docs/make-store-shots.sh"
  },
  "devDependencies": {
    "addons-linter": "^10.6.0",
    "crx3": "^1.1.3",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.4.1"
  }
}
