# Chrome Web Store API credentials for `npm run submit:cws`.
# Copy to .env (gitignored) and fill in. NEVER commit the real values.
# One-time setup instructions: .github/RELEASE_SETUP.md → "Automating CWS submission".

# OAuth2 client (Google Cloud Console → Credentials → Web application)
CWS_CLIENT_ID=
CWS_CLIENT_SECRET=

# OAuth2 refresh token with the https://www.googleapis.com/auth/chromewebstore scope
CWS_REFRESH_TOKEN=

# Published item ID. Optional — defaults to the Adhan Caster Pro listing ID.
# CWS_EXTENSION_ID=jfjknglldcdminelckmmfdbnlikiogia
